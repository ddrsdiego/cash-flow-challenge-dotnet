{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },
  "AllowedHosts": "*",
  "Authentication": {
    "Authority": "http://localhost:8080/realms/cashflow",
    "Audience": "cashflow-api",
    "RequireHttpsMetadata": false
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 60
  },
  "OpenTelemetry": {
    "ServiceName": "cashflow-gateway",
    "OtlpEndpoint": "http://localhost:4317"
  },
  "ReverseProxy": {
    "Routes": {
      "transactions-route": {
        "ClusterId": "transactions",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/v1/transactions/{**catch-all}"
        }
      },
      "consolidation-route": {
        "ClusterId": "consolidation",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/v1/consolidation/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "transactions": {
        "Destinations": {
          "default": {
            "Address": "http://localhost:8081"
          }
        }
      },
      "consolidation": {
        "Destinations": {
          "default": {
            "Address": "http://localhost:8082"
          }
        }
      }
    }
  }
}
