# ============================================
# CashFlow System — Environment Configuration
# ============================================
# Este arquivo é lido automaticamente pelo Docker Compose.
# Copie para .env e ajuste os valores conforme necessário:
#   cp .env.example .env
#
# ATENÇÃO: Em produção, NUNCA commite o .env no repositório.
#          Use secrets manager ou variáveis do CI/CD.
# ============================================

# --- General ---
# Nome do projeto Docker Compose (prefixo dos containers)
COMPOSE_PROJECT_NAME=cashflow

# ============================================
# DATA STORES
# ============================================

# --- MongoDB ---
# Usuário root criado na primeira inicialização do container.
# Usado apenas pelo script mongo-init.js para criar databases e users.
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=Mongo@CashFlow2024!

# Databases criados pelo mongo-init.js (um por serviço — database-per-service pattern)
MONGO_TRANSACTIONS_DB=transactions_db
MONGO_CONSOLIDATION_DB=consolidation_db

# Usuário aplicacional com permissão readWrite nos databases acima.
# Usado pelas connection strings dos serviços .NET.
MONGO_APP_USERNAME=cashflow_app
MONGO_APP_PASSWORD=CashFlowApp@2024!

# Porta exposta no host (acesso local via mongosh/Compass)
MONGO_PORT=27017

# --- Redis ---
# Senha do Redis. Usada no comando --requirepass e nas connection strings .NET.
REDIS_PASSWORD=Redis@CashFlow2024!
REDIS_PORT=6379

# ============================================
# MESSAGE BROKER
# ============================================

# --- RabbitMQ ---
# Credenciais do broker. Usadas pelos serviços .NET para publicar/consumir mensagens.
# O vhost "cashflow" e filas são criados via definitions.json (infra/config/rabbitmq/).
RABBITMQ_DEFAULT_USER=cashflow
RABBITMQ_DEFAULT_PASS=RabbitMQ@CashFlow2024!
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# ============================================
# IDENTITY PROVIDER
# ============================================

# --- Keycloak ---
# Credenciais do admin console do Keycloak (http://localhost:8443).
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=Keycloak@CashFlow2024!
KEYCLOAK_PORT=8443

# --- PostgreSQL (exclusivo do Keycloak) ---
# O Keycloak precisa de um banco relacional para persistir realms, users, roles.
# Estes valores são usados tanto pelo container postgres quanto pelo Keycloak.
KEYCLOAK_DB=keycloak_db
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=KeycloakDB@2024!
POSTGRES_PORT=5432

# ============================================
# APPLICATION SERVICES
# ============================================

# Portas dos serviços .NET expostas no host.
# O Gateway é o único ponto de entrada externo.
GATEWAY_PORT=8080
TRANSACTIONS_API_PORT=8081
CONSOLIDATION_API_PORT=8082

# ============================================
# OBSERVABILITY
# ============================================

# --- OpenTelemetry Collector ---
# Recebe traces, metrics e logs dos serviços .NET via OTLP.
OTEL_COLLECTOR_GRPC_PORT=4317
OTEL_COLLECTOR_HTTP_PORT=4318

# --- Jaeger ---
# UI para visualização de traces distribuídos.
JAEGER_UI_PORT=16686

# --- Prometheus ---
# Scrape de métricas do OTel Collector e RabbitMQ.
PROMETHEUS_PORT=9090

# --- Grafana ---
# Dashboards unificados (métricas + traces).
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=Grafana@CashFlow2024!

# --- Seq ---
# Agregação de logs estruturados. Recebe logs via OTLP do OTel Collector.
# UI: http://localhost:8341  |  Ingestion: http://localhost:5341
SEQ_PORT=5341
SEQ_UI_PORT=8341
